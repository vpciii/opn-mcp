# OPNsense API connection
OPNSENSE_HOST=192.168.1.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here

# TLS verification is ON by default (ADR 0005). For a self-signed or
# private-CA certificate, point OPNSENSE_CA_BUNDLE at the CA's PEM file:
#OPNSENSE_CA_BUNDLE=/path/to/ca.pem
# Explicit opt-out (not recommended) — only the literal "false" disables:
#OPNSENSE_VERIFY_SSL=false
